{
  "name": "lava-sprint-timer",
  "version": "1.0.0",
  "description": "Session focus timer for Lava — loads CURRENT.md, sets Pomodoro timer, auto-commits session end to lava-ice-logs",
  "bin": {
    "sprint": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/cli.ts",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "simple-git": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.2"
  },
  "type": "module",
  "engines": {
    "node": ">=18"
  }
}
