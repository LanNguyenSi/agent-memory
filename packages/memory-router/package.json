{
  "name": "memory-router",
  "version": "0.1.0",
  "description": "Retrieval and policy layer for Claude-Code memory files — decides when and which memories to inject based on topic, tool-call, and confidence gates.",
  "bin": {
    "memory-router": "./dist/cli.js",
    "memory-router-user-prompt-submit": "./dist/hooks/user-prompt-submit.js",
    "memory-router-pre-tool-use": "./dist/hooks/pre-tool-use.js",
    "memory-router-mcp": "./dist/mcp/server.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.test.json",
    "lint": "npm run typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "pretest": "npm run build",
    "test": "node --import tsx --test tests/**/*.test.ts"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.9.0",
    "sqlite-vec": "^0.1.9",
    "yaml": "^2.6.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.2",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
